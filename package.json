{
  "name": "fpc-corinth-bulletin",
  "version": "1.0.0",
  "description": "Digital bulletin for First Presbyterian Church of Corinth",
  "scripts": {
    "dev": "npx @11ty/eleventy --serve --watch",
    "build": "npx tailwindcss -i ./src/css/input.css -o ./src/css/style.css && npx @11ty/eleventy",
    "build:css": "npx tailwindcss -i ./src/css/input.css -o ./src/css/style.css --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "tailwindcss": "^3.4.0"
  }
}
