---
layout: base.njk
title: Current Bulletin
---

{# Find the latest bulletin across both markdown and scroll formats #}
{% set latest = collections.bulletins | getLatest %}
{% set latestDate = "" %}
{% set latestUrl = "" %}

{% if latest %}
  {% set latestDate = latest.data.date | dateToPath %}
  {% set latestUrl = "/" + latestDate + "/" %}
{% endif %}

{% for sb in scrollBulletins %}
  {% if sb.date > latestDate %}
    {% set latestDate = sb.date %}
    {% set latestUrl = sb.url %}
  {% endif %}
{% endfor %}

{% if latestUrl %}
  <div class="text-center py-12">
    <p>Redirecting to the latest bulletin...</p>
    <p><a href="{{ latestUrl }}">Click here if not redirected</a></p>
  </div>
  <script>
    // Only redirect if no identity token in URL
    if (!window.location.hash.includes('token')) {
      window.location.href = "{{ latestUrl }}";
    }
  </script>
{% else %}
  <div class="text-center py-12">
    <h1 class="font-serif text-2xl text-navy dark:text-cream mb-4">Welcome to FPC Corinth</h1>
    <p class="text-navy/70 dark:text-gray-400 mb-6">No bulletins have been published yet.</p>
    <a href="/about/" class="text-gold hover:underline">Learn more about our church →</a>
  </div>
{% endif %}
