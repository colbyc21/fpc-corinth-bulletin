---
eleventyExcludeFromCollections: true
permalink: /index.html
---
{# Find the latest bulletin across both markdown and scroll formats #}
{% set latest = collections.bulletins | getLatest %}
{% set latestDate = "" %}
{% set latestUrl = "" %}

{% if latest %}
  {% set latestDate = latest.data.date | dateToPath %}
  {% set latestUrl = "/" + latestDate + "/" %}
{% endif %}

{% for sb in scrollBulletins %}
  {% if sb.date > latestDate %}
    {% set latestDate = sb.date %}
    {% set latestUrl = sb.url %}
  {% endif %}
{% endfor %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>FPC Corinth Bulletin</title>
{% if latestUrl %}<meta http-equiv="refresh" content="0; url={{ latestUrl }}">{% endif %}
<style>
  html, body { margin: 0; background: #f0ebe0; color: #2a2118; font-family: 'Georgia', serif; }
  .pending { display: flex; align-items: center; justify-content: center; min-height: 100vh; font-size: 0.95rem; color: #7a7060; }
</style>
</head>
<body>
{% if latestUrl %}
<div class="pending"><a href="{{ latestUrl }}" style="color:#7a7060;">Loading latest bulletin…</a></div>
<script>
  if (!window.location.hash.includes('token')) {
    window.location.replace("{{ latestUrl }}");
  }
</script>
{% else %}
<div class="pending">No bulletins published yet. <a href="/about/" style="margin-left:0.4rem;color:#8b1a1a;">About</a></div>
{% endif %}
</body>
</html>
