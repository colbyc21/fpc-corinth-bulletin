<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Sunday Bulletin") }} | FPC Corinth</title>
  <meta name="description" content="{{ description | default("Digital bulletin for First Presbyterian Church of Corinth, MS") }}">

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- Theme color for mobile browsers -->
  <meta name="theme-color" content="#1a3a5c" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#111827" media="(prefers-color-scheme: dark)">

  <!-- PWA manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">

  <!-- Apple touch icon -->
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">

  <script>
    // Check for dark mode preference
    if (localStorage.getItem('darkMode') === 'true' ||
        (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
      document.body.classList.add('dark');
    }
  </script>
</head>
<body class="min-h-screen">
  <header class="bg-navy text-cream py-4 px-4 sticky top-0 z-50 no-print">
    <div class="max-w-2xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <span class="font-serif text-lg">FPC Corinth</span>
      </a>
      <nav class="flex items-center gap-4">
        <a href="/archive/" class="text-sm hover:text-gold transition-colors">Archive</a>
        <button id="darkModeToggle" class="p-2 hover:text-gold transition-colors" aria-label="Toggle dark mode">
          <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
        </button>
      </nav>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-6">
    {{ content | safe }}
  </main>

  <footer class="bg-navy/5 dark:bg-gray-800 py-8 px-4 mt-12 no-print">
    <div class="max-w-2xl mx-auto text-center text-sm text-navy/70 dark:text-gray-400">
      <p class="font-serif text-lg mb-2">First Presbyterian Church of Corinth</p>
      <p class="italic mb-4">"To Be Disciples / To Make Disciples"</p>
      <p>A congregation of the Evangelical Presbyterian Church (EPC)</p>
      <a href="/about/" class="text-gold hover:underline mt-4 inline-block">About & Service Times</a>
    </div>
  </footer>

  <script src="/js/main.js"></script>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
